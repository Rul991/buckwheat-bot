{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "level": {
            "type": "number"
        },
        "experience": {
            "type": "number"
        },
        "result": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "count": {
                    "type": "number"
                }
            },
            "required": [
                "name"
            ],
            "additionalProperties": false
        },
        "materials": {
            "type": "object",
            "propertyNames": {
                "type": "string"
            },
            "additionalProperties": {
                "type": "number"
            }
        }
    },
    "required": [
        "level",
        "experience",
        "result",
        "materials"
    ],
    "additionalProperties": false
}