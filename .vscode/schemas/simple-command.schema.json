{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "name": {
            "type": "string"
        },
        "src": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            ]
        },
        "text": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            ]
        },
        "avoidOther": {
            "type": "boolean"
        },
        "aliases": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "name"
    ],
    "additionalProperties": false
}