{
    "name": "buckwheat-bot",
    "version": "1.5.8",
    "main": "src/app/index.ts",
    "scripts": {
        "dev": "bun run --watch .",
        "start": "bun run .",
        "start:prod": "bunx bm2 start bm2.config.js --env prod",
        "restart:prod": "bun install && bunx bm2 restart buckwheat-bot",
        "stop:prod": "bunx bm2 stop bm2.config.js && bunx bm2 delete bm2.config.js"
    },
    "keywords": [
        "telegraf",
        "mongoose",
        "buckwheat",
        "bot",
        "telegram"
    ],
    "author": "Rul",
    "license": "CC BY-NC",
    "description": "",
    "devDependencies": {
        "@types/express": "^5.0.3",
        "@types/node": "^25.3.5",
        "@types/pug": "^2.0.10",
        "@types/bun": "^1.3.10"
    },
    "dependencies": {
        "bm2": "^1.0.21",
        "express": "^5.1.0",
        "mongoose": "^9.1.4",
        "p-queue": "^9.0.1",
        "pug": "^3.0.3",
        "socks-proxy-agent": "^8.0.5",
        "telegraf": "^4.16.3",
        "typescript": "^5.9.3",
        "zod": "^4.3.5"
    },
    "packageManager": "bun@1.3.10"
}