include utils/functions.pug
include utils/mixins.pug

- const medals = ['🥇', '🥈', '🥉']
- const firstPlace = 1

- let startIndex = page * perPage
- const fullTitle = rawTitle || `Топ самых ${property} игроков`
- const hasTotalCount = totalCount != 0

mixin line(user, value)
    - 
        const index = ++startIndex
        const listNumber = index <= medals.length && hasWinner ?
            medals[index - 1] : 
            `${index}`.padStart(3, '0')
        const showableValue = typeof value == 'string' ?
            value :
            formatNumber(value)
    | #{listNumber}. 
    +link(user)
    | - 
    i #{showableValue} 
    if index == firstPlace && hasTotalCount
        | (#{Math.floor(100 * 100 * +value / totalCount) / 100}%)
    |
    |

b  #{emoji} #{fullTitle}:
|
|
|
each obj in sorted
    - let user = obj.user
    - let value = obj.value

    +line(user, value)
|
|
if hasTotalCount
    b 🎖 Суммарно#{totalName ? ` ${totalName}` : ''}: 
    code #{formatNumber(totalCount)}
    |
    |
if playerPlace
    |
    i 🏆 Ваше место - 
        code #{formatNumber(playerPlace)}
        | !