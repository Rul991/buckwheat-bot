include utils/mixins.pug

- const medals = ['🥇', '🥈', '🥉']

- let number = page * perPage
- const fullTitle = rawTitle || `Топ самых ${property} игроков`

mixin line(user, value)
    - const index = ++number
    | #{user.isLeft ? '✖️' : index <= medals.length && hasWinner ? medals[index - 1] : `${index}`.padStart(3, '0')}. 
    +link(user)
    | - 
    i #{value}
    |
    |

code (#{page + 1} / #{length})
b  #{emoji} #{fullTitle}:
|
|
|
each obj in sorted
    - let user = obj.user
    - let value = obj.value
    - let isLeft = user.isLeft

    if isLeft
        s
            +line(
                {
                    name: user.name, 
                    link: 'https://t.me/buckwheat_channel',
                    isLeft: true
                }, 
                value
            )
    else
        +line(user, value)
    |
|
|
if isNumbers && rawTotalCount != 0
    b 🎖 Суммарно#{totalName ? ` ${totalName}` : ''}: 
    code #{totalCount}